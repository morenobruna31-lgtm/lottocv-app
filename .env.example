# ─────────────────────────────────────────
# LottoCV — Variáveis de Ambiente
# Copia este ficheiro para .env e preenche
# ─────────────────────────────────────────

# Telegram Bot (obter em @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI

# E-mail (opcional — podes usar Gmail com App Password)
EMAIL_REMETENTE=o_teu_email@gmail.com
EMAIL_PASSWORD=app_password_do_gmail
EMAIL_DESTINATARIO=destino@email.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Limiar do jackpot para alertas críticos (em ECV)
# 40.000.000 = 40.000 contos
JACKPOT_CRITICO=40000000
